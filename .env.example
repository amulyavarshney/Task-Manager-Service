# Copy this file to .env and fill in your values.
# Used by Spring (${...} placeholders) and docker-compose.

DB_URL=jdbc:postgresql://localhost:5432/taskmanager
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# Comma-separated browser origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8088

# Optional executor tuning
# TASK_EXECUTOR_CORE=2
# TASK_EXECUTOR_MAX=4
# TASK_EXECUTOR_QUEUE=10
