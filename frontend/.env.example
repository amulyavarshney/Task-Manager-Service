# Optional. Leave empty when using Vite proxy (dev) or nginx proxy (Docker).
# Set to absolute API origin only when the UI is hosted on a different host, e.g.:
# VITE_API_URL=http://localhost:8080
VITE_API_URL=

# Optional default API key (also configurable in the UI header key dialog)
VITE_API_KEY=dev-admin-key
